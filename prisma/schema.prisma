generator client {
  provider     = "prisma-client"
  output       = "./generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Bet {
  id String @id @default(nanoid())

  status           BetStatus @default(PENDING)
  amount           Decimal   @db.Decimal(12, 2)
  totalCoefficient Decimal   @map("total_coefficient") @db.Decimal(10, 2)
  potentialPayout  Decimal   @map("potential_payout") @db.Decimal(12, 2)
  actualPayout     Decimal?  @map("actual_payout") @db.Decimal(12, 2)

  eventId     String @map("event_id")
  outcomeId   String @map("outcome_id")
  eventName   String @map("event_name")
  outcomeName String @map("outcome_name")

  userId String @map("user_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([eventId])
  @@index([userId])
  @@index([status])
  @@map("bets")
}

enum BetStatus {
  PENDING
  WON
  LOST
  CANCELLED
}
